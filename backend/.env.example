# Database
DATABASE_URL=postgresql+asyncpg://mistake:password@localhost:5432/mistake
DATABASE_URL_SYNC=postgresql://mistake:password@localhost:5432/mistake

# JWT
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# S3 / Object Storage
S3_ENDPOINT=https://your-s3-endpoint.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=your-bucket-name
S3_REGION=us-east-1

# AI / OCR
OPENAI_API_KEY=your-aliyun-api-key
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Environment
ENVIRONMENT=development
SQL_ECHO=false
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Export worker
EXPORT_WORKER_AUTO_START=true
EXPORT_WORKER_POLL_INTERVAL_SECONDS=1
EXPORT_RETENTION_DAYS=7
EXPORT_CLEANUP_INTERVAL_SECONDS=3600

# Init admin (used by INIT.py)
INIT_ADMIN_EMAIL=admin@example.com
INIT_ADMIN_PASSWORD=change-this-password
